// ═════════════════════════════════════════════════════════════════════════════
//  Griselle — Aeronautical Maintenance SaaS
//  Prisma Schema  ·  Professional Data Model
// ═════════════════════════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
//  ENUMS
// ─────────────────────────────────────────────────────────────────────────────

/// Subscription tiers for the SaaS model
enum SubscriptionPlan {
  FREE
  PROFESSIONAL
  ENTERPRISE

  @@map("subscription_plan")
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELLED
  SUSPENDED

  @@map("subscription_status")
}

/// Aeronautical operational status — AOG is a critical blocking state
enum AircraftStatus {
  OPERATIONAL       // Available for flight
  AOG               // Aircraft On Ground — grounded due to defect
  IN_MAINTENANCE    // Planned maintenance check in progress
  GROUNDED          // Administratively grounded (e.g., expired cert)
  DECOMMISSIONED    // Permanently withdrawn from service

  @@map("aircraft_status")
}

enum ComponentStatus {
  INSTALLED         // Currently fitted to an aircraft
  SERVICEABLE       // In store, ready for installation
  UNSERVICEABLE     // Removed and awaiting shop action
  IN_SHOP           // Under repair/overhaul at a MRO
  SCRAPPED          // Beyond economic repair, disposed

  @@map("component_status")
}

/// Interval type driving a maintenance task's recurrence
enum TaskIntervalType {
  FLIGHT_HOURS      // e.g. every 100 flight hours
  CYCLES            // e.g. every 500 landings
  CALENDAR_DAYS     // e.g. every 365 days
  FLIGHT_HOURS_OR_CALENDAR // whichever comes first
  CYCLES_OR_CALENDAR
  ON_CONDITION      // Condition-monitored, no fixed interval

  @@map("task_interval_type")
}

/// Regulatory/technical reference classification
enum ReferenceType {
  AMM               // Aircraft Maintenance Manual
  AD                // Airworthiness Directive (mandatory)
  SB                // Service Bulletin (manufacturer)
  CMR               // Certification Maintenance Requirement
  CDCCL             // Critical Design Configuration Control Limitation
  MPD               // Maintenance Planning Document
  ETOPS             // Extended Operations requirement
  INTERNAL          // Operator-defined task

  @@map("reference_type")
}

enum ComplianceStatus {
  COMPLETED
  DEFERRED          // Officially deferred with MEL/NEF reference
  OVERDUE           // Past due date/hours — requires immediate attention
  CANCELLED

  @@map("compliance_status")
}

/// Work order lifecycle — transitions enforced by WorkOrderService
enum WorkOrderStatus {
  DRAFT         // Borrador — being assembled, not yet executable
  OPEN          // Abierta — approved, ready to execute
  IN_PROGRESS   // En ejecución — work has started
  QUALITY       // En calidad — awaiting independent inspector sign-off
  CLOSED        // Cerrada — inspector approved and signed off

  @@map("work_order_status")
}

/// Work order assignment lifecycle — tracks technician assignment and evidence
enum WorkOrderAssignmentStatus {
  PENDING              // Esperando asignación de técnico
  ASSIGNED             // Técnico asignado, pendiente de ejecución
  IN_PROGRESS          // En ejecución por técnico
  AWAITING_EVIDENCE    // Ejecución completada, esperando foto/PDF
  EVIDENCE_UPLOADED    // Fotografía/PDF recibida
  CLOSED               // OT cerrada y finalizada

  @@map("work_order_assignment_status")
}

/// Type of evidence file attached to work order
enum WorkOrderEvidenceType {
  PHOTO     // Fotografía digital del trabajo firmado
  PDF       // Documento PDF firmado digitalmente
  BOTH      // Foto y PDF adjuntos

  @@map("work_order_evidence_type")
}

/// Work request (Solicitud de Trabajo / ST) lifecycle
enum WorkRequestStatus {
  DRAFT       // Borrador editable
  SENT        // Enviada al responsable CMA/OT
  CANCELLED   // Cancelada

  @@map("work_request_status")
}

enum WorkRequestItemCategory {
  MAINTENANCE_PLAN
  NORMATIVE
  COMPONENT_INSPECTION
  DISCREPANCY
  OTHER

  @@map("work_request_item_category")
}

enum DiscrepancyStatus {
  OPEN          // Hallazgo abierto, pendiente de acción
  DEFERRED      // Diferido con referencia MEL/CDL
  RESOLVED      // Resuelto, trabajo completado
  CANCELLED     // Cancelado (error de registro, etc.)

  @@map("discrepancy_status")
}

enum ComponentMovementType {
  INSTALLED     // Componente instalado en aeronave
  REMOVED       // Componente removido de aeronave

  @@map("component_movement_type")
}

enum UserRole {
  ADMIN             // Full access, user management
  SUPERVISOR        // Approve work orders, sign-off compliances
  TECHNICIAN        // Perform and record maintenance work
  INSPECTOR         // Independent inspection sign-off (RII)
  READONLY          // View-only (auditors, clients)

  @@map("user_role")
}

// ─────────────────────────────────────────────────────────────────────────────
//  ORGANIZATION  (Multi-tenant root)
// ─────────────────────────────────────────────────────────────────────────────

model Organization {
  id                 String             @id @default(uuid()) @db.Uuid
  name               String             @db.VarChar(255)
  slug               String             @unique @db.VarChar(100)
  legalName          String?            @db.VarChar(255)
  country            String             @db.Char(2)          // ISO 3166-1 alpha-2
  subscriptionPlan   SubscriptionPlan   @default(FREE)
  subscriptionStatus SubscriptionStatus @default(TRIALING)
  subscriptionExpiresAt DateTime?
  isActive           Boolean            @default(true)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  // Relations
  users              User[]
  aircraft           Aircraft[]
  components         Component[]
  maintenanceTasks   MaintenanceTask[]
  compliances        Compliance[]
  workOrders         WorkOrder[]
  workRequests       WorkRequest[]
  discrepancies      Discrepancy[]
  maintenanceTemplates MaintenanceTemplate[]

  @@map("organizations")
}

// ─────────────────────────────────────────────────────────────────────────────
//  USERS  (Tenant-scoped, with aeronautical roles)
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  email          String   @db.VarChar(255)
  name           String   @db.VarChar(255)
  passwordHash   String
  role           UserRole @default(TECHNICIAN)

  /// Aircraft Maintenance Engineer licence number (EASA Part-66, FAA A&P, etc.)
  licenseNumber  String?  @db.VarChar(50)
  licenseExpiry  DateTime?

  /// Authorization codes for specific maintenance tasks (e.g., engine run-up)
  certifications String[] @default([])
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  /// Compliances the user performed (technician sign-off)
  compliancesPerformed  Compliance[]    @relation("PerformedBy")
  /// Compliances the user inspected (inspector independent sign-off)
  compliancesInspected  Compliance[]    @relation("InspectedBy")

  workOrdersCreated        WorkOrder[]    @relation("WOCreatedBy")
  workOrdersAssignedTechnician WorkOrder[] @relation("WOAssignedTechnician")
  workOrdersInspecting     WorkOrder[]    @relation("WOInspector")
  workOrdersClosed         WorkOrder[]    @relation("WOClosedBy")
  workOrdersEvidenceUploaded WorkOrder[]   @relation("WOEvidenceUploadedBy")
  workOrderTasksCompleted  WorkOrderTask[] @relation("WOTaskCompletedBy")
  workRequestsCreated      WorkRequest[]   @relation("WRCreatedBy")
  workRequestsResponsible  WorkRequest[]   @relation("WRResponsible")
  workRequestsSentBy       WorkRequest[]   @relation("WRSentBy")
  discrepanciesFound       Discrepancy[]  @relation("DiscrepancyFoundBy")
  discrepanciesResolved    Discrepancy[]  @relation("DiscrepancyResolvedBy")
  componentMovements       ComponentHistory[] @relation("ComponentMovedBy")

  @@unique([email, organizationId])
  @@index([organizationId])
  @@map("users")
}

// ─────────────────────────────────────────────────────────────────────────────
//  AIRCRAFT  (MAT = Matrícula, primary registration identifier)
// ─────────────────────────────────────────────────────────────────────────────

model Aircraft {
  id                 String        @id @default(uuid()) @db.Uuid
  organizationId     String        @db.Uuid

  /// Registration mark (MAT) — unique within the organization, used as PK reference in operations
  registration       String        @db.VarChar(20)             // e.g. XA-GRI, EC-MJF

  model              String        @db.VarChar(150)            // e.g. Boeing 737-800
  manufacturer       String        @db.VarChar(150)            // e.g. Boeing
  serialNumber       String        @db.VarChar(100)            // Manufacturer's serial number (MSN)
  engineCount        Int           @default(2)

  /// Engine model for combined airframe+engine task applicability
  engineModel        String?       @db.VarChar(100)

  /// Accumulated flight hours since new (Hobbs / Airframe Total Time)
  totalFlightHours   Decimal       @default(0) @db.Decimal(10, 2)

  /// Landings / pressurisation cycles since new
  totalCycles        Int           @default(0)

  /// Current status — AOG triggers alerts across all open orders
  status             AircraftStatus @default(OPERATIONAL)

  manufactureDate    DateTime?     @db.Date
  registrationDate   DateTime?     @db.Date

  /// Certificate of Airworthiness expiry
  coaExpiryDate      DateTime?     @db.Date

  /// Insurance expiry date
  insuranceExpiryDate DateTime?    @db.Date

  isActive           Boolean       @default(true)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  // Relations
  organization       Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  components         Component[]

  /// M:N — which maintenance tasks apply to this aircraft
  applicableTasks    AircraftTask[]
  compliances        Compliance[]
  workOrders         WorkOrder[]
  workRequests       WorkRequest[]
  componentHistory   ComponentHistory[]

  // Indexes for common lookups
  @@unique([registration, organizationId])
  @@index([organizationId])
  @@index([registration])                    // fast search by MAT
  @@index([status, organizationId])          // AOG dashboard queries
  @@map("aircraft")
}

// ─────────────────────────────────────────────────────────────────────────────
//  COMPONENT  (EQ — Equipamiento con trazabilidad de número de serie)
// ─────────────────────────────────────────────────────────────────────────────

model Component {
  id             String          @id @default(uuid()) @db.Uuid
  organizationId String          @db.Uuid

  /// Currently installed on which aircraft (null = in store/shop)
  aircraftId     String?         @db.Uuid

  /// Part Number (P/N) — identifies the component type/design
  partNumber     String          @db.VarChar(100)

  /// Serial Number (S/N) — uniquely identifies this physical unit
  serialNumber   String          @db.VarChar(100)

  description    String          @db.VarChar(255)
  manufacturer   String          @db.VarChar(150)

  /// Where on the aircraft this is installed (e.g. "Engine 1 (CFM56-7B)", "LH MLG")
  position       String?         @db.VarChar(100)

  // ── Life tracking ──────────────────────────────────────────────────────────

  /// Total Accumulated Hours since new (used for TBO/life-limit checks)
  totalHoursSinceNew    Decimal  @default(0) @db.Decimal(10, 2)

  /// Total Accumulated Cycles since new
  totalCyclesSinceNew   Int      @default(0)

  /// Total Hours since last overhaul (resets at each shop visit)
  hoursSinceOverhaul    Decimal  @default(0) @db.Decimal(10, 2)

  /// Cycles since last overhaul
  cyclesSinceOverhaul   Int      @default(0)

  // ── TBO limits ─────────────────────────────────────────────────────────────

  /// Time Between Overhaul — hours limit (null = not applicable)
  tboHours       Decimal?        @db.Decimal(10, 2)

  /// Time Between Overhaul — cycles limit
  tboCycles      Int?

  /// Time Between Overhaul — calendar days limit
  tboCalendarDays Int?

  // ── Hard life limits (cannot be extended) ─────────────────────────────────

  lifeLimitHours  Decimal?       @db.Decimal(10, 2)
  lifeLimitCycles Int?

  // ── Installation data (populated when component is fitted) ─────────────────

  installationDate    DateTime?  @db.Date
  /// Aircraft hours at the time of installation (for interval tracking)
  installationAircraftHours Decimal? @db.Decimal(10, 2)
  installationAircraftCycles Int?

  status         ComponentStatus @default(SERVICEABLE)
  isActive       Boolean         @default(true)
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  // Relations
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  aircraft       Aircraft?       @relation(fields: [aircraftId], references: [id])

  /// M:N — which maintenance tasks apply to this component
  applicableTasks ComponentTask[]
  compliances     Compliance[]
  history         ComponentHistory[]
  workRequestItems WorkRequestItem[]

  @@unique([serialNumber, organizationId])
  @@index([organizationId])
  @@index([aircraftId])
  @@index([partNumber, organizationId])
  @@index([status, organizationId])
  @@map("components")
}

// ─────────────────────────────────────────────────────────────────────────────
//  MAINTENANCE TASK  (Task Definition / Card)
//  Represents the DEFINITION of an inspection, overhaul, replacement, etc.
//  Actual execution is recorded in Compliance.
// ─────────────────────────────────────────────────────────────────────────────

model MaintenanceTask {
  id             String          @id @default(uuid()) @db.Uuid
  organizationId String          @db.Uuid

  /// Human-readable task code (e.g. "50H-INSP", "A-CHECK", "AD-2024-15-01")
  code           String          @db.VarChar(100)

  title          String          @db.VarChar(255)
  description    String

  intervalType   TaskIntervalType

  // ── Recurrence intervals (set the applicable ones based on intervalType) ───

  /// Primary interval in flight hours (e.g. 100.00)
  intervalHours  Decimal?        @db.Decimal(10, 2)

  /// Primary interval in cycles/landings
  intervalCycles Int?

  /// Primary interval in calendar days (e.g. 365 for annual)
  intervalCalendarDays Int?

  /// Primary interval in calendar months (e.g. 6 for semestral)
  intervalCalendarMonths Int?

  // ── Tolerances (grace period before task becomes overdue) ──────────────────

  toleranceHours       Decimal?  @db.Decimal(8, 2)
  toleranceCycles      Int?
  toleranceCalendarDays Int?

  // ── Regulatory/technical reference ────────────────────────────────────────

  /// Reference identifier (AD number, AMM chapter/section, SB number)
  referenceNumber String?        @db.VarChar(100)
  referenceType   ReferenceType  @default(AMM)

  /// True = regulatory mandatory (AD, CMR). False = manufacturer/operator rec.
  isMandatory     Boolean        @default(false)

  /// Estimated man-hours to perform the task
  estimatedManHours Decimal?     @db.Decimal(6, 2)

  /// Whether an independent inspection (RII) is required after this task
  requiresInspection Boolean     @default(false)

  /// Specific aircraft model this task applies to (null = all models)
  applicableModel String?        @db.VarChar(150)

  /// Specific part number this task applies to (null = aircraft-level task)
  applicablePartNumber String?   @db.VarChar(100)

  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // Relations
  organization    Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  /// M:N — aircraft that have this task assigned
  aircraftLinks   AircraftTask[]

  /// M:N — components that have this task assigned
  componentLinks  ComponentTask[]

  compliances     Compliance[]
  workOrderTasks  WorkOrderTask[]
  workRequestItems WorkRequestItem[]

  @@unique([code, organizationId])
  @@index([organizationId])
  @@index([isMandatory, organizationId])
  @@index([referenceType, organizationId])
  @@map("maintenance_tasks")
}

// ─────────────────────────────────────────────────────────────────────────────
//  AIRCRAFT TASK  (M:N join — aircraft ↔ maintenance tasks)
// ─────────────────────────────────────────────────────────────────────────────

model AircraftTask {
  id         String   @id @default(uuid()) @db.Uuid

  aircraftId String   @db.Uuid
  taskId     String   @db.Uuid

  /// Override interval at aircraft level (e.g. operator escalation approved by authority)
  overrideIntervalHours  Decimal? @db.Decimal(10, 2)
  overrideIntervalCycles Int?

  isActive   Boolean  @default(true)
  assignedAt DateTime @default(now())

  aircraft   Aircraft        @relation(fields: [aircraftId], references: [id], onDelete: Cascade)
  task       MaintenanceTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([aircraftId, taskId])
  @@index([aircraftId])
  @@index([taskId])
  @@map("aircraft_tasks")
}

// ─────────────────────────────────────────────────────────────────────────────
//  COMPONENT TASK  (M:N join — component ↔ maintenance tasks)
// ─────────────────────────────────────────────────────────────────────────────

model ComponentTask {
  id          String   @id @default(uuid()) @db.Uuid

  componentId String   @db.Uuid
  taskId      String   @db.Uuid

  isActive    Boolean  @default(true)
  assignedAt  DateTime @default(now())

  component   Component       @relation(fields: [componentId], references: [id], onDelete: Cascade)
  task        MaintenanceTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([componentId, taskId])
  @@index([componentId])
  @@index([taskId])
  @@map("component_tasks")
}

// ─────────────────────────────────────────────────────────────────────────────
//  COMPLIANCE  (Cumplimiento — historical record of task execution)
//  This is the audit core. Once written, records must be immutable.
// ─────────────────────────────────────────────────────────────────────────────

model Compliance {
  id             String           @id @default(uuid()) @db.Uuid
  organizationId String           @db.Uuid

  /// The aircraft this compliance record belongs to
  aircraftId     String           @db.Uuid

  /// The task definition that was performed
  taskId         String           @db.Uuid

  /// The component this compliance applies to (null = airframe-level task)
  componentId    String?          @db.Uuid

  /// Technician who performed the work
  performedById  String           @db.Uuid

  /// Inspector who independently verified the work (RII sign-off, null if not required)
  inspectedById  String?          @db.Uuid

  // ── When it was done ───────────────────────────────────────────────────────

  performedAt           DateTime
  /// Aircraft total hours at time of compliance
  aircraftHoursAtCompliance  Decimal   @db.Decimal(10, 2)
  /// Aircraft total cycles at time of compliance
  aircraftCyclesAtCompliance Int

  // ── Next due values (pre-calculated at record time) ───────────────────────
  //  These are IMMUTABLE after creation — next cycle recalculates from new compliance

  nextDueHours          Decimal?   @db.Decimal(10, 2)
  nextDueCycles         Int?
  nextDueDate           DateTime?  @db.Date

  // ── Work order reference ──────────────────────────────────────────────────

  /// Internal work order number linking to the maintenance package
  workOrderNumber String?          @db.VarChar(50)

  status         ComplianceStatus  @default(COMPLETED)

  /// If deferred: MEL/NEF item reference and expiry
  deferralReference String?        @db.VarChar(100)
  deferralExpiresAt DateTime?

  notes          String?
  createdAt      DateTime          @default(now())

  // ── No updatedAt — compliance records should be append-only ──────────────

  // Relations
  organization   Organization      @relation(fields: [organizationId], references: [id])
  aircraft       Aircraft          @relation(fields: [aircraftId], references: [id])
  task           MaintenanceTask   @relation(fields: [taskId], references: [id])
  component      Component?        @relation(fields: [componentId], references: [id])
  performedBy    User              @relation("PerformedBy", fields: [performedById], references: [id])
  inspectedBy    User?             @relation("InspectedBy", fields: [inspectedById], references: [id])

  // ── Indexes for the two most critical queries ─────────────────────────────
  // 1. "What is the current due-status for each task on this aircraft?"
  @@index([aircraftId, taskId])
  // 2. "What tasks are overdue / coming due across the fleet?"
  @@index([nextDueHours, organizationId])
  @@index([nextDueDate, organizationId])
  @@index([organizationId, status])
  @@index([componentId])
  @@map("compliances")
}

// ─────────────────────────────────────────────────────────────────────────────
//  WORK ORDER  (Orden de Trabajo / OT)
//  Central work package. State machine: DRAFT→OPEN→IN_PROGRESS→QUALITY→CLOSED
// ─────────────────────────────────────────────────────────────────────────────

model WorkOrder {
  id             String          @id @default(uuid()) @db.Uuid
  organizationId String          @db.Uuid

  /// Sequential WO number scoped to org (e.g. OT-2024-001)
  number         String          @db.VarChar(50)

  aircraftId     String          @db.Uuid
  title          String          @db.VarChar(255)
  description    String?

  status         WorkOrderStatus @default(DRAFT)

  /// User who opened/created this WO
  createdById    String          @db.Uuid

  /// Technician(s) assigned to execute the work
  assignedTechnicianId String?   @db.Uuid

  /// Inspector responsible for quality/close sign-off (must have INSPECTOR role)
  inspectorId    String?         @db.Uuid

  // ── Scheduling ────────────────────────────────────────────────────────────
  plannedStartDate DateTime?     @db.Date
  plannedEndDate   DateTime?     @db.Date
  actualStartDate  DateTime?
  actualEndDate    DateTime?

  // ── Assignment workflow ────────────────────────────────────────────────────
  /// Tracks assignment status separately from main WorkOrderStatus
  assignmentStatus WorkOrderAssignmentStatus @default(PENDING)

  /// Timestamp when technician was assigned
  assignedAt          DateTime?

  // ── Evidencia y cierre ─────────────────────────────────────────────────────
  /// File URL for evidence (photo, signed PDF) — stored in S3/bucket
  evidenceFileUrl     String?    @db.VarChar(500)

  /// Original filename of evidence
  evidenceFileName    String?    @db.VarChar(255)

  /// When evidence was uploaded
  evidenceUploadedAt  DateTime?

  /// Who uploaded the evidence (usually the technician)
  evidenceUploadedBy  String?    @db.Uuid

  /// Type of evidence file
  evidenceType        WorkOrderEvidenceType?

  // ── Aircraft state snapshot at open/close ─────────────────────────────────
  aircraftHoursAtOpen    Decimal?   @db.Decimal(10, 2)
  aircraftCyclesAtOpen   Int?
  aircraftHoursAtClose   Decimal?   @db.Decimal(10, 2)
  aircraftCyclesAtClose  Int?

  /// User who performed the final close sign-off (must have INSPECTOR role)
  closedById     String?         @db.Uuid
  closedAt       DateTime?

  notes          String?
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  // Relations
  organization         Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  aircraft             Aircraft        @relation(fields: [aircraftId], references: [id])
  createdBy            User            @relation("WOCreatedBy",    fields: [createdById],            references: [id])
  assignedTechnician   User?           @relation("WOAssignedTechnician", fields: [assignedTechnicianId], references: [id])
  inspector            User?           @relation("WOInspector",    fields: [inspectorId],            references: [id])
  evidenceUploadedByUser User?         @relation("WOEvidenceUploadedBy", fields: [evidenceUploadedBy], references: [id])
  closedBy             User?           @relation("WOClosedBy",     fields: [closedById],             references: [id])

  tasks                WorkOrderTask[]
  discrepancies        Discrepancy[]
  componentMovements   ComponentHistory[]
  auditLogs            AuditLog[]

  @@unique([number, organizationId])
  @@index([organizationId])
  @@index([aircraftId])
  @@index([status, organizationId])
  @@index([assignmentStatus])
  @@index([assignedTechnicianId])
  @@index([createdById])
  @@map("work_orders")
}

// ─────────────────────────────────────────────────────────────────────────────
//  WORK ORDER TASK  (Task line-items within a WO)
// ─────────────────────────────────────────────────────────────────────────────

model WorkOrderTask {
  id             String   @id @default(uuid()) @db.Uuid
  workOrderId    String   @db.Uuid
  taskId         String   @db.Uuid

  /// Whether the technician has completed and signed off this task
  isCompleted    Boolean  @default(false)
  completedAt    DateTime?
  completedById  String?  @db.Uuid
  notes          String?

  workOrder      WorkOrder       @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  task           MaintenanceTask @relation(fields: [taskId],      references: [id])
  completedBy    User?           @relation("WOTaskCompletedBy",  fields: [completedById], references: [id])

  @@unique([workOrderId, taskId])
  @@index([workOrderId])
  @@index([taskId])
  @@map("work_order_tasks")
}

// ─────────────────────────────────────────────────────────────────────────────
//  WORK REQUEST  (Solicitud de Trabajo / ST)
//  Editable container that can group multiple maintenance tasks before dispatch
// ─────────────────────────────────────────────────────────────────────────────

model WorkRequest {
  id             String            @id @default(uuid()) @db.Uuid
  organizationId String            @db.Uuid
  aircraftId     String            @db.Uuid

  /// Sequential ST number scoped to org (e.g. ST-2026-0001)
  number         String            @db.VarChar(50)

  status         WorkRequestStatus @default(DRAFT)

  /// User who created/assembled the request
  createdById    String            @db.Uuid

  /// Responsible user in CMA / Oficina Tecnica
  responsibleId  String?           @db.Uuid

  /// Snapshot values captured at ST creation
  aircraftHoursAtRequest Decimal?  @db.Decimal(10, 2)
  aircraftCyclesN1       Int?
  aircraftCyclesN2       Int?

  /// Dispatch tracking
  sentAt         DateTime?
  sentById       String?           @db.Uuid

  notes          String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  aircraft       Aircraft          @relation(fields: [aircraftId], references: [id])
  createdBy      User              @relation("WRCreatedBy", fields: [createdById], references: [id])
  responsible    User?             @relation("WRResponsible", fields: [responsibleId], references: [id])
  sentBy         User?             @relation("WRSentBy", fields: [sentById], references: [id])

  items          WorkRequestItem[]

  @@unique([number, organizationId])
  @@index([organizationId, status])
  @@index([aircraftId, status])
  @@index([responsibleId])
  @@map("work_requests")
}

/// Join table for WorkRequest <-> MaintenanceTask (M:N)
model WorkRequestItem {
  id            String          @id @default(uuid()) @db.Uuid
  workRequestId String          @db.Uuid
  taskId        String?         @db.Uuid
  componentId   String?         @db.Uuid
  discrepancyId String?         @db.Uuid

  category      WorkRequestItemCategory @default(MAINTENANCE_PLAN)
  itemCode      String?         @db.VarChar(100)
  itemTitle     String          @db.VarChar(255)
  itemDescription String?

  /// Why this task was added (AUTO threshold / manual grouping)
  source        String          @default("AUTO") @db.VarChar(20)
  addedAt       DateTime        @default(now())

  workRequest   WorkRequest     @relation(fields: [workRequestId], references: [id], onDelete: Cascade)
  task          MaintenanceTask? @relation(fields: [taskId], references: [id])
  component     Component?      @relation(fields: [componentId], references: [id])
  discrepancy   Discrepancy?    @relation(fields: [discrepancyId], references: [id])

  @@index([workRequestId, category])
  @@index([taskId])
  @@index([componentId])
  @@index([discrepancyId])
  @@map("work_request_items")
}

// ─────────────────────────────────────────────────────────────────────────────
//  DISCREPANCY  (Hallazgo / Discrepancia within a WO)
//  Non-routine findings raised during execution. May be deferred via MEL/CDL.
// ─────────────────────────────────────────────────────────────────────────────

model Discrepancy {
  id             String            @id @default(uuid()) @db.Uuid
  organizationId String            @db.Uuid
  workOrderId    String            @db.Uuid

  /// Auto-generated sequential code: DC-{YEAR}-{SEQ} scoped to org
  code           String            @db.VarChar(50)

  title          String            @db.VarChar(255)
  description    String

  /// Physical location on aircraft (e.g. "LH flap track 3", "Frame 23")
  location       String?           @db.VarChar(150)

  /// Criticality / ATA chapter reference
  ataChapter     String?           @db.VarChar(20)

  status         DiscrepancyStatus @default(OPEN)

  foundById      String            @db.Uuid
  resolvedById   String?           @db.Uuid
  resolvedAt     DateTime?
  resolutionNotes String?

  /// MEL/CDL deferral reference and expiry (if DEFERRED)
  deferralRef    String?           @db.VarChar(100)
  deferralExpiresAt DateTime?

  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  // Relations
  organization   Organization      @relation(fields: [organizationId], references: [id])
  workOrder      WorkOrder         @relation(fields: [workOrderId],    references: [id], onDelete: Cascade)
  foundBy        User              @relation("DiscrepancyFoundBy",     fields: [foundById],     references: [id])
  resolvedBy     User?             @relation("DiscrepancyResolvedBy",  fields: [resolvedById],  references: [id])
  workRequestItems WorkRequestItem[]

  @@index([workOrderId])
  @@index([organizationId, status])
  @@map("discrepancies")
}

// ─────────────────────────────────────────────────────────────────────────────
//  AUDIT LOG  (Trazabilidad — IMMUTABLE append-only log for DGAC compliance)
//  Never update or delete rows. Foreign keys are intentionally left as strings
//  so logs survive referenced entity deletion.
// ─────────────────────────────────────────────────────────────────────────────

model AuditLog {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid

  /// Entity type that changed (e.g. "WorkOrder", "Discrepancy", "Compliance")
  entityType     String   @db.VarChar(50)

  /// UUID of the changed entity
  entityId       String   @db.Uuid

  /// Human-readable action label (e.g. "STATUS_CHANGED", "TASK_COMPLETED", "DISCREPANCY_CREATED")
  action         String   @db.VarChar(100)

  /// Snapshot of the relevant field(s) before the change
  previousValue  Json?

  /// Snapshot of the relevant field(s) after the change
  newValue       Json?

  /// User who caused the change
  userId         String   @db.Uuid
  userEmail      String   @db.VarChar(255)
  userRole       String   @db.VarChar(50)

  /// Optional metadata (IP, user-agent, notes)
  metadata       Json?

  /// ── No updatedAt — this table is append-only ──
  createdAt      DateTime @default(now())

  // Optional relation to WorkOrder for quick lookups (nullable — log survives WO deletion)
  workOrderId    String?  @db.Uuid
  workOrder      WorkOrder? @relation(fields: [workOrderId], references: [id])

  @@index([entityType, entityId])
  @@index([organizationId])
  @@index([userId])
  @@index([workOrderId])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
//  COMPONENT HISTORY  (Historial de instalación/remoción de componentes)
//  Append-only. One row per installation, one row per removal.
// ─────────────────────────────────────────────────────────────────────────────

model ComponentHistory {
  id             String               @id @default(uuid()) @db.Uuid
  organizationId String               @db.Uuid

  componentId    String               @db.Uuid
  aircraftId     String               @db.Uuid

  movementType   ComponentMovementType

  // ── Aircraft state at time of movement ────────────────────────────────────
  aircraftHoursAtMovement   Decimal   @db.Decimal(10, 2)
  aircraftCyclesAtMovement  Int

  // ── Component accumulated state at time of movement ───────────────────────
  componentHoursAtMovement  Decimal   @db.Decimal(10, 2)
  componentCyclesAtMovement Int

  /// Position on aircraft (e.g. "Engine 1", "LH MLG", "Nose Gear")
  position       String?              @db.VarChar(150)

  /// Work order that authorized this movement (optional)
  workOrderId    String?              @db.Uuid

  performedById  String               @db.Uuid
  notes          String?

  movedAt        DateTime

  /// ── No updatedAt — this table is append-only ──
  createdAt      DateTime             @default(now())

  // Relations
  component      Component            @relation(fields: [componentId], references: [id])
  aircraft       Aircraft             @relation(fields: [aircraftId],  references: [id])
  workOrder      WorkOrder?           @relation(fields: [workOrderId], references: [id])
  performedBy    User                 @relation("ComponentMovedBy",    fields: [performedById], references: [id])

  @@index([componentId])
  @@index([aircraftId])
  @@index([organizationId])
  @@index([workOrderId])
  @@map("component_history")
}

// ─────────────────────────────────────────────────────────────────────────────
//  MAINTENANCE TEMPLATE  (Biblioteca Maestra de Mantenimiento)
//  Almacena planes estándar por Fabricante/Modelo para reutilizar en nuevas aeronaves
// ─────────────────────────────────────────────────────────────────────────────

model MaintenanceTemplate {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid

  /// Aircraft manufacturer (e.g. "Airbus", "Boeing", "Beechcraft")
  manufacturer   String   @db.VarChar(150)

  /// Aircraft model (e.g. "AS350 B3", "737-800", "Twin Otter")
  model          String   @db.VarChar(150)

  /// Human-readable description of this template
  description    String?

  /// Version number for tracking changes (e.g. "1.0", "2.1")
  version        String   @default("1.0") @db.VarChar(20)

  /// Template is available for use when creating new aircraft
  isActive       Boolean  @default(true)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tasks          MaintenanceTemplateTask[]

  @@unique([manufacturer, model, organizationId])
  @@index([organizationId])
  @@index([manufacturer])
  @@index([model])
  @@map("maintenance_templates")
}

// ─────────────────────────────────────────────────────────────────────────────
//  MAINTENANCE TEMPLATE TASK  (Tareas que forman parte de una plantilla)
// ─────────────────────────────────────────────────────────────────────────────

model MaintenanceTemplateTask {
  id         String   @id @default(uuid()) @db.Uuid
  templateId String   @db.Uuid

  /// Task code — human-readable identifier (e.g. "50H-INSP", "04-10-00", "AD-2024-15")
  code       String   @db.VarChar(100)

  /// Short title of the task
  title      String   @db.VarChar(255)

  /// Detailed description of the task
  description String

  /// AMM/SB chapter classification (e.g. "04-10-00" for Airbus, "32-51-00" for engines)
  chapter    String?  @db.VarChar(20)

  /// Section/category within chapter (e.g. "ALS", "MSM", "ECS")
  section    String?  @db.VarChar(50)

  // ── Interval configuration ─────────────────────────────────────────────────

  /// Type of interval control (hours, cycles, calendar, or combination)
  intervalType       TaskIntervalType

  /// Interval in flight hours (nullable if not applicable)
  intervalHours      Decimal?        @db.Decimal(10, 2)

  /// Interval in cycles/landings
  intervalCycles     Int?

  /// Interval in calendar days
  intervalCalendarDays Int?

  /// Interval in calendar months
  intervalCalendarMonths Int?

  // ── Regulatory/Reference info ──────────────────────────────────────────────

  /// Reference number (AD#, SB#, etc.)
  referenceNumber String?        @db.VarChar(100)

  /// Type of reference (AMM, AD, SB, etc.)
  referenceType   ReferenceType  @default(AMM)

  /// True if regulatory mandatory
  isMandatory     Boolean        @default(false)

  /// Estimated man-hours to perform
  estimatedManHours Decimal?     @db.Decimal(6, 2)

  /// True if independent inspection (RII) required after task
  requiresInspection Boolean     @default(false)

  /// Specific aircraft model applicability (inherited from template)
  applicableModel String?        @db.VarChar(150)

  /// Specific part number applicability
  applicablePartNumber String?   @db.VarChar(100)

  // Metadata
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  // Relations
  template       MaintenanceTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, code])
  @@index([templateId])
  @@index([chapter])
  @@map("maintenance_template_tasks")
}
